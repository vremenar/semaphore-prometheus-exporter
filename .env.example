# ============================================================
# Semaphore Prometheus Exporter — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Required ---
# Base URL of your Semaphore UI instance (no trailing slash)
SEMAPHORE_URL=http://semaphore:3000

# API token generated in Semaphore UI → User settings → API Tokens
SEMAPHORE_API_TOKEN=your-api-token-here

# --- Networking ---
# Port exposed on the Docker host for the /metrics endpoint
EXPORTER_PORT=9090

# --- Scraping ---
# How often to fetch data from Semaphore (Go duration: 30s, 5m, 1h, etc.)
SCRAPE_INTERVAL=30m

# Maximum number of events (audit log entries) to fetch and expose
MAX_EVENTS=100

# HTTP timeout for requests to Semaphore UI
HTTP_TIMEOUT=30s

# Set to true to skip TLS certificate verification (NOT recommended for production)
INSECURE_SKIP_VERIFY=false

# --- Cache ---
# Host directory to mount for persistent cache storage
# Change this to an absolute path if needed (e.g. /var/lib/semaphore-exporter)
CACHE_DATA_PATH=./data
